generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Donation {
  id          Int      @id @default(autoincrement())
  amount      Float
  donorName   String?
  donorEmail  String?
  donorPhone  String?
  blessing    String?
  slipUrl     String?
  taxId       String?
  address     String?
  date        DateTime @default(now())
  status      String   @default("pending")
}

model WebsiteSetting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

model VisitorLog {
  id        Int      @id @default(autoincrement())
  path      String
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
}
